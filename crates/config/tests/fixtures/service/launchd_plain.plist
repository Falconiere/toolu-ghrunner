<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.toolu.runner.octocat.hello</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/toolu-runner</string>
    <string>run</string>
